rm frontend/.gitignore
rm backend/.gitignore

cat > .gitignore << 'EOF'
# Dependencies
node_modules/
**/node_modules/

# Environment variables (NEVER commit these — contain secrets)
.env
.env.local
**/.env
**/.env.local

# Build output
dist/
build/
**/dist/
**/build/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
EOF